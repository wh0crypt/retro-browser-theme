{
    "manifest_version": 3,
    "name": "Retro 70s Terminal Theme",
    "version": "1.1",
    "description": "Turn your browser into a classic terminal from the 70s.",
    "chrome_url_overrides": {
        "newtab": "ntp.html"
    },
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "exclude_matches": [
                "*://*/*.pdf",
                "*://*/*.PDF"
            ],
            "css": [
                "global-retro.css"
            ],
            "run_at": "document_end"
        }
    ]
}